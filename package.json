{
  "name": "jonuffyspoofer",
  "version": "1.5.0",
  "main": "main.js",
  "description": "Animation spoofing utility for Roblox",
  "author": "Jonuffy",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "plugin": "node scripts/builder.js"
  },
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "@electron/rebuild": "^4.0.3"
  },
  "build": {
    "appId": "com.github.jonuffykk.JonuffySpoofer",
    "productName": "Jonuffy Spoofer",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "modules/**/*",
      "assets/**/*",
      "build/**/*",
      "package.json",
      "!**/.git/**/*",
      "!**/node_modules/.cache/**/*",
      "!downloads/**/*",
      "!dist/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "dist/JonuffySpoofer-v${version}.rbxmx",
        "to": "JonuffySpoofer-v${version}.rbxmx"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "assets/logo.ico",
      "signAndEditExecutable": false
    },
    "artifactName": "JonuffySpoofer-${version}.${ext}",
    "forceCodeSigning": false,
    "publish": {
      "provider": "github",
      "owner": "jonuffykk",
      "repo": "JonuffySpoofer"
    }
  }
}
